# LifePilot Backend Environment Configuration

# Application
APP_NAME=LifePilot
APP_VERSION=0.1.0
DEBUG=true
ENVIRONMENT=development

# API
API_V1_PREFIX=/api/v1

# Security
SECRET_KEY=change-me-in-production-use-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# CORS (comma-separated list of origins)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database (PostgreSQL with asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/lifepilot
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# S3/R2 Storage
S3_BUCKET_NAME=lifepilot-storage
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT_URL=  # For Cloudflare R2 or MinIO

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Google OAuth (Requirement 1.3)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# Data Encryption at Rest (Requirement 36.1)
# Master key for encrypting sensitive data in the database.
# Generate a new key with: python -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
# IMPORTANT: Keep this key secure and backed up. Losing it means losing access to encrypted data!
ENCRYPTION_MASTER_KEY=change-me-in-production-generate-a-32-byte-key
